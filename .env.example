# Prefer a Stripe test-mode restricted key with Checkout Sessions read and write access.
STRIPE_SECRET_KEY=rk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Live keys are rejected unless this is explicitly enabled.
ALLOW_LIVE_STRIPE=false

STRIPE_CURRENCY=gbp
PRINT_BASE_PRICE_PENCE=800
PRINT_PRICE_PER_CM3_PENCE=25
UNLIMITED_EXPORTS_PRICE_PENCE=500
STRIPE_ALLOWED_COUNTRIES=GB,US

# Required when the frontend and checkout API use different origins.
CHECKOUT_ALLOWED_ORIGIN=
CHECKOUT_RETURN_ORIGIN=

# Account authentication and database.
SUPABASE_URL=https://your-project-reference.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me

# Used to sign short-lived permits for the single sponsored STL download.
DOWNLOAD_TOKEN_SECRET=replace_with_a_long_random_value
