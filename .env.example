# Prefer a Stripe test-mode restricted key with Checkout Sessions read and write access.
STRIPE_SECRET_KEY=rk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_API_VERSION=2026-05-27.dahlia

# Live keys are rejected unless this is explicitly enabled.
ALLOW_LIVE_STRIPE=false

STRIPE_CURRENCY=gbp
PRINT_BASE_PRICE_PENCE=800
PRINT_PRICE_PER_CM3_PENCE=25
MARKETPLACE_PLATFORM_FEE_PENCE=50
MARKETPLACE_COMMISSION_PERCENT=10
MARKETPLACE_VAT_PERCENT=20
MARKETPLACE_QUOTE_MINUTES=30
PLA_COST_PER_GRAM_PENCE=2
PRINT_AUTO_COMPLETE_DAYS=14
# Keep false for live-style testing. Set true only when deliberately testing pending-review printers.
MARKETPLACE_INCLUDE_PENDING=false
UNLIMITED_EXPORTS_PRICE_PENCE=500
STRIPE_ALLOWED_COUNTRIES=GB,US

# Comma-separated browser origins allowed to call the backend.
CHECKOUT_ALLOWED_ORIGIN=https://forgetabout.im,https://watsonjohn-spec.github.io
CHECKOUT_RETURN_ORIGIN=
PUBLIC_API_BASE_URL=https://forget-about-tray.onrender.com
PRODUCTION_ORIGIN=https://forgetabout.im

# Public analytics and launch-hold settings. These values are safe to expose to browsers.
GA4_MEASUREMENT_ID=G-NDKFRQ10CJ
CLARITY_PROJECT_ID=xc7u4g2p1w
COOKIE_CONSENT_REQUIRED=true
LAUNCH_HOLD_ENABLED=true
FACTORY_LAUNCH_HOLD_ENABLED=true
MVP_LAUNCH_MODE=true
LAUNCH_PUBLIC_PATHS=tray,print,factory
LAUNCH_DEFERRED_PATHS=makeup,paint,stitch
LAUNCH_HOLD_EXCLUDED_PATHS=hub

# Public Google AdSense settings. Use AdSense publisher/ad-unit values, not Google Ads advertiser IDs.
ADSENSE_ENABLED=true
ADSENSE_CLIENT_ID=ca-pub-6722120388841444
# Use "google-cmp" when the AdSense Privacy & messaging European-regulations
# message is configured. Use "local" only for non-CMP test environments.
ADSENSE_CONSENT_PROVIDER=google-cmp
ADSENSE_TEST_MODE=false
ADSENSE_SLOT_DEFAULT=
ADSENSE_SLOT_HOME_TOP=
ADSENSE_SLOT_HOME_BOTTOM=
ADSENSE_SLOT_TRAY_TOP=
ADSENSE_SLOT_TRAY_BOTTOM=
ADSENSE_SLOT_MAKEUP_TOP=
ADSENSE_SLOT_MAKEUP_BOTTOM=
ADSENSE_SLOT_PRINT_TOP=
ADSENSE_SLOT_PRINT_BOTTOM=
ADSENSE_SLOT_PAINT_TOP=
ADSENSE_SLOT_PAINT_BOTTOM=
ADSENSE_SLOT_STITCH_TOP=
ADSENSE_SLOT_STITCH_BOTTOM=
ADSENSE_SLOT_FACTORY_TOP=
ADSENSE_SLOT_FACTORY_BOTTOM=
ADSENSE_SLOT_EXPORT_PREP=

# Account authentication and database.
SUPABASE_URL=https://your-project-reference.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me
HUB_ADMIN_EMAILS=watson.john@live.co.uk

# Optional email used by Create Factory Login.cmd. The password is generated each time.
FACTORY_PROTOTYPE_EMAIL=factory.prototype@forgetabout.im

# Used to sign short-lived permits for the single first free STL export.
DOWNLOAD_TOKEN_SECRET=replace_with_a_long_random_value
# Optional prototype-only fallback. Keep false outside throwaway local testing.
ALLOW_PROTOTYPE_SECRET_FALLBACK=false

# Secret used by a cron/worker calling POST /api/tasks/auto-complete-posted.
TASK_RUNNER_SECRET=replace_with_a_second_long_random_value

# Keep false until account device-management controls are available.
ACCOUNT_DEVICE_LIMIT=3
ENFORCE_ACCOUNT_DEVICE_LIMIT=false

# Optional Founder Console assumption used for cash runway. Leave 0 until real monthly fixed costs are known.
MONTHLY_FIXED_COST_PENCE=0
